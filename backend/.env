# =============================================================================
# VARIABLES D'ENVIRONNEMENT — Renommez ce fichier en ".env"
# =============================================================================
# Ce fichier contient les informations sensibles (mots de passe, clés secrètes).
# Il ne doit JAMAIS être commité dans Git.
# Ajoutez ".env" dans votre .gitignore !
#
# Copiez ce fichier et renommez la copie en ".env" :
#   cp .env.example .env
# Puis éditez .env avec vos vraies valeurs.
# =============================================================================

# ── Configuration MySQL (WAMP) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=asecna_db

# ── Clé secrète Admin ─────────────────────────────────────────────────────────
# Changez cette valeur ! N'utilisez jamais la valeur par défaut en production.
ADMIN_SECRET_KEY=ASECNA2025SECRET
